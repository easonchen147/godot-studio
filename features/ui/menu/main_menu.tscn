[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://features/ui/menu/main_menu.gd" id="1_main_menu"]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_main_menu")

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -220.0
offset_top = -190.0
offset_right = 220.0
offset_bottom = 190.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "Godot Studio Starter"
horizontal_alignment = 1

[node name="VersionLabel" type="Label" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Godot Studio Starter 4.7"
horizontal_alignment = 1

[node name="StartButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "Start Sample"

[node name="OptionsButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "Options"

[node name="CreditsButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "Credits"

[node name="ShaderShowcaseButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "Shader Showcase"

[node name="QuitButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "Quit"

[connection signal="pressed" from="Panel/VBox/StartButton" to="." method="_on_start_pressed"]
[connection signal="pressed" from="Panel/VBox/OptionsButton" to="." method="_on_options_pressed"]
[connection signal="pressed" from="Panel/VBox/CreditsButton" to="." method="_on_credits_pressed"]
[connection signal="pressed" from="Panel/VBox/ShaderShowcaseButton" to="." method="_on_shader_showcase_pressed"]
[connection signal="pressed" from="Panel/VBox/QuitButton" to="." method="_on_quit_pressed"]
