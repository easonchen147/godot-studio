[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://features/ui/menu/options_menu.gd" id="1_options_menu"]

[node name="OptionsMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_options_menu")

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -280.0
offset_top = -230.0
offset_right = 280.0
offset_bottom = 230.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "Options"
horizontal_alignment = 1

[node name="MasterLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "Master Volume"

[node name="MasterSlider" type="HSlider" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
max_value = 1.0
step = 0.01
value = 1.0

[node name="MasterMute" type="CheckBox" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Mute Master"

[node name="MusicLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "Music Volume"

[node name="MusicSlider" type="HSlider" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
max_value = 1.0
step = 0.01
value = 0.7

[node name="MusicMute" type="CheckBox" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Mute Music"

[node name="SfxLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "SFX Volume"

[node name="SfxSlider" type="HSlider" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
max_value = 1.0
step = 0.01
value = 0.85

[node name="SfxMute" type="CheckBox" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Mute SFX"

[node name="DebugToggle" type="CheckBox" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Show Debug Overlay"

[node name="FullscreenToggle" type="CheckBox" parent="Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Fullscreen"

[node name="BackButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "Back"

[connection signal="value_changed" from="Panel/VBox/MasterSlider" to="." method="_on_master_slider_value_changed"]
[connection signal="value_changed" from="Panel/VBox/MusicSlider" to="." method="_on_music_slider_value_changed"]
[connection signal="value_changed" from="Panel/VBox/SfxSlider" to="." method="_on_sfx_slider_value_changed"]
[connection signal="toggled" from="Panel/VBox/MasterMute" to="." method="_on_master_mute_toggled"]
[connection signal="toggled" from="Panel/VBox/MusicMute" to="." method="_on_music_mute_toggled"]
[connection signal="toggled" from="Panel/VBox/SfxMute" to="." method="_on_sfx_mute_toggled"]
[connection signal="toggled" from="Panel/VBox/DebugToggle" to="." method="_on_debug_toggle_toggled"]
[connection signal="toggled" from="Panel/VBox/FullscreenToggle" to="." method="_on_fullscreen_toggle_toggled"]
[connection signal="pressed" from="Panel/VBox/BackButton" to="." method="_on_back_pressed"]
