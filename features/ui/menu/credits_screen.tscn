[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://features/ui/menu/credits_screen.gd" id="1_credits"]

[node name="CreditsScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_credits")

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -260.0
offset_top = -160.0
offset_right = 260.0
offset_bottom = 160.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "Credits"
horizontal_alignment = 1

[node name="Body" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "Template systems: Godot Studio Starter 4.7
Replace this text with your project credits."
horizontal_alignment = 1

[node name="BackButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "Back"

[connection signal="pressed" from="Panel/VBox/BackButton" to="." method="_on_back_pressed"]
